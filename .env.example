# Copy this file to .env and fill in. .env is gitignored.

# FBI Crime Data Explorer API key (free, sign up at https://api.data.gov/signup)
FBI_CDE_API_KEY=

# Census Bureau API key (free, sign up at https://api.census.gov/data/key_signup.html)
# Used for ACS demographic and economic controls at the city level.
CENSUS_API_KEY=

# Identity for PIA submissions (used by scripts/pia_*.py helpers when they exist)
PIA_FIRST_NAME=Brennan
PIA_LAST_NAME=Griffin
PIA_EMAIL=brennan.griffin@gmail.com
PIA_ORG=
PIA_PHONE=
